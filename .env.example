# 复制本文件为 .env.local 后填写真实密钥（勿提交 Git）

# Replicate — https://replicate.com/account/api-tokens（WhisperX）
VITE_REPLICATE_API_TOKEN=r8_你的真实密钥

# Deepgram — https://console.deepgram.com（Nova-2 预录转写）
VITE_DEEPGRAM_API_KEY=你的Deepgram密钥
# VITE_DEEPGRAM_MODEL=nova-2
# 顶栏可选 nova-3；日语建议源语言固定 ja，关闭 Smart Format

# WhisperX 模型版本（非官方模型必填 version hash，见 versions 页）
# VITE_WHISPERX_VERSION=victor-upmeet/whisperx:655845d6190ef70573c669245f245892cd039df4b880a1e3a65852c09252f5cc

# JieKou AI — https://api.jiekou.ai/openai
VITE_LLM_API_BASE_URL=https://api.jiekou.ai/openai
VITE_LLM_API_KEY=你的JieKou密钥
VITE_LLM_MODEL=gpt-4o-mini

# HuggingFace（说话人分离时必填）
VITE_HUGGINGFACE_TOKEN=hf_你的真实密钥

# 客户端「建议上限」提示（MB），默认 500；不等于 Replicate 实际上传上限
# VITE_MAX_UPLOAD_MB=500
